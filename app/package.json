{
  "name": "cttc-timeline",
  "version": "0.0.1",
  "description": "Correlate container telemetry with service logs on a shared clickable timeline",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test:unit": "node --test test/unit/*.test.js",
    "test:e2e": "./test/run-e2e.sh",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:win:zip": "electron-builder --win zip --x64",
    "release:win": "../releases/windows/build-image/build-bundle.sh"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.olivierbien67.cttc",
    "productName": "CTTC",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "lib/**/*",
      "package.json",
      "!server/**",
      "!demo/**",
      "!test/**"
    ],
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      { "from": "../releases/windows/build-image/cttc-server.tar.gz", "to": "cttc-server.tar.gz" },
      { "from": "../releases/windows/build-image/docker-compose.yml", "to": "docker-compose.offline.yml" },
      { "from": "../releases/windows/repo/image.json", "to": "image.json" },
      { "from": "../releases/windows/repo/docker-compose.yml", "to": "docker-compose.registry.yml" }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}

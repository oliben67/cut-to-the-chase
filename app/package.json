{
  "name": "cttc-timeline",
  "version": "0.0.1",
  "description": "Correlate container telemetry with service logs on a shared clickable timeline",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test:unit": "node --test test/unit/*.test.js",
    "test:e2e": "./test/run-e2e.sh",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:win:zip": "electron-builder --win zip --x64",
    "dist:win:slim": "electron-builder --win nsis --x64 --config electron-builder.win-slim.json",
    "dist:mac": "electron-builder --mac dmg",
    "dist:linux": "electron-builder --linux AppImage",
    "release:win": "../releases/windows/build-bundle.sh",
    "release:mac": "../releases/macos/build-bundle.sh",
    "release:linux": "../releases/linux/build-bundle.sh"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.olivierbien67.cttc",
    "productName": "CTTC",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "lib/**/*",
      "package.json",
      "!server/**",
      "!demo/**",
      "!test/**"
    ],
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      { "from": "../releases/_repo/image.json", "to": "image.json" },
      { "from": "../releases/_repo/docker-compose.yml", "to": "docker-compose.registry.yml" }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.png",
      "extraResources": [
        { "from": "../releases/_shared/cttc-server.tar.gz", "to": "cttc-server.tar.gz" },
        { "from": "../releases/_shared/docker-compose.yml", "to": "docker-compose.offline.yml" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Development"
    }
  }
}
